<main>

  <!-- 2. BARRA DE CATEGORÍAS -->
  <nav class="categories-bar">
    <div class="category"><i class="fas fa-laptop"></i><span>Electrónica</span></div>
    <div class="category"><i class="fas fa-apple-alt"></i><span>Alimentos</span></div>
    <div class="category"><i class="fas fa-wine-glass-alt"></i><span>Bebidas</span></div>
    <div class="category"><i class="fas fa-shirt"></i><span>Indumentaria</span></div>
    <div class="category"><i class="fas fa-gamepad"></i><span>Juegos</span></div>
    <div class="category"><i class="fas fa-car"></i><span>Automotor</span></div>
    <div class="category"><i class="fas fa-house"></i><span>Hogar</span></div>
    <div class="category"><i class="fas fa-gift"></i><span>Otros</span></div>
  </nav>

  <!-- 3. BLOQUE DE PROMOCIONES -->
  <section class="hero-section">
    <div class="promo-card">
      <a href="https://www.disneyplus.com/es-ar">
        <img src="/assets/combo_plus.jpeg" alt="Promo 1" />
      </a>
      <div class="promo-info">
        <h4>50% OFF en Combo Plus</h4>
        <p>Canjeando 50.000 puntos MiEcommerce.</p>
      </div>
    </div>
    <div class="promo-card">
      <a href="https://www.max.com/ar/es">
        <img src="/assets/promo_hbo.jpeg" alt="Promo 2" />
      </a>
      <div class="promo-info">
        <h4>50% OFF en HBO Max</h4>
        <p>Canjeando 50.000 puntos MiEcommerce.</p>
      </div>
    </div>
  </section>

  <!-- 4. SECCIÓN: "Te puede interesar" -->
  <section class="products-section">
    <h2 class="section-title">Te puede interesar</h2>
    <div class="products-grid">
      <% suggestedProducts.forEach(function(product) { %>
        <a href="/products/<%= product.id %>" class="product-card">
          <img
            src="<%= product.image || '/assets/fallback.svg' %>"
            alt="<%= product.name %>"
            onerror="this.onerror=null; this.src='/assets/fallback.svg'"
          />
          <p class="product-title"><%= product.name %></p>
          <p class="product-price"><%= product.price.toLocaleString('es-AR') %> <span class="puntos-label">puntos</span></p>
        </a>
      <% }) %>
    </div>
  </section>

  <!-- 5. SECCIÓN: "Los más pedidos" -->
 <section class="products-section">
  <h2 class="section-title">Los más pedidos</h2>
  <div class="products-grid">
    <% featuredProducts.forEach(function(product) { %>
      <a href="/products/<%= product.id %>" class="product-card">
        <img
          src="<%= product.image || '/assets/fallback.svg' %>"
          alt="<%= product.name %>"
          onerror="this.onerror=null; this.src='/assets/fallback.svg'"
        />
        <p class="product-title"><%= product.name %></p>
        <p class="product-price"><%= product.price.toLocaleString('es-AR') %> <span class="puntos-label">puntos</span></p>
      </a>
    <% }) %>
  </div>
</section>
<%- include('../partials/productCard') %>
</main>