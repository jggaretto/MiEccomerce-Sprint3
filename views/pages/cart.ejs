<main class="cart-container">

  <div class="cart-back">
    <a href="/index"><i class="bi bi-arrow-left"></i> Volver</a>
  </div>

  <h1 class="cart-title">Productos en tu Carrito</h1>

  <% if (cartItems.length === 0) { %>
    <div class="cart-empty">
      <i class="bi bi-cart-x cart-empty-icon"></i>
      <p>Tu carrito está vacío.</p>
      <a href="/index" class="btn-checkout">Ver productos</a>
    </div>

  <% } else { %>

    <div class="cart-items">
      <% cartItems.forEach(function(item) { %>
        <div class="cart-item">
          <img
            src="<%= item.image || '/assets/fallback.svg' %>"
            alt="<%= item.name %>"
            onerror="this.onerror=null; this.src='/assets/fallback.svg'"
          />

          <div class="item-info">
            <p class="item-name"><%= item.name %></p>
            <p class="item-unit-price"><%= item.price.toLocaleString('es-AR') %> puntos c/u</p>
          </div>

          <div class="item-actions">
            <div class="quantity-control">
              <form action="/cart/decrease" method="POST" style="display:inline">
                <input type="hidden" name="productId" value="<%= item.productId %>" />
                <button type="submit" class="qty-btn">➖</button>
              </form>

              <span class="qty-number"><%= item.quantity %></span>

              <form action="/cart/increase" method="POST" style="display:inline">
                <input type="hidden" name="productId" value="<%= item.productId %>" />
                <button type="submit" class="qty-btn">➕</button>
              </form>
            </div>
          </div>

          <p class="item-price"><%= item.subtotal.toLocaleString('es-AR') %></p>
        </div>
      <% }) %>
    </div>

    <div class="cart-summary">
      <p class="total-label">Total de Puntos</p>
      <p class="total-value"><%= total.toLocaleString('es-AR') %></p>

      <div class="cart-actions">
        <form action="/cart/clear" method="POST">
          <button type="submit" class="btn-clear-cart">Vaciar carrito</button>
        </form>
        <a href="/checkout" class="btn-checkout">Ir a Pagar</a>
      </div>
    </div>

  <% } %>

</main>