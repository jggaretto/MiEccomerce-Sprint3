
<main>
  <section class="products-section">

    <div class="sort-bar">
      <span>Ordenar por precio:</span>
      <a href="/products?sort=asc" class="sort-btn <%= sort === 'asc' ? 'active' : '' %>">
        Menor a mayor ↑
      </a>
      <a href="/products?sort=desc" class="sort-btn <%= sort === 'desc' ? 'active' : '' %>">
        Mayor a menor ↓
      </a>
      <a href="/products" class="sort-btn <%= !sort ? 'active' : '' %>">
        Sin orden
      </a>
    </div>

    <h2 class="section-title">Todos los productos</h2>

    <div class="products-grid">
      <% products.forEach(function(product) { %>
        <a href="/products/<%= product.id %>" class="product-card">
          <img
            src="<%= product.image || '/assets/fallback.svg' %>"
            alt="<%= product.name %>"
            onerror="this.onerror=null; this.src='/assets/fallback.svg'"
          />
          <p class="product-title"><%= product.name %></p>
          <p class="product-price">
            <%= product.price.toLocaleString('es-AR') %>
            <span class="puntos-label">puntos</span>
          </p>
        </a>
      <% }) %>
    </div>

  </section>
</main>

