<main class="product-container">
  <div class="product-back">
    <a href="/index">
      <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
  </div>

  <div class="product-main">
    <div class="product-image">
      <img
        src="<%= product.image || '/assets/fallback.svg' %>"
        alt="<%= product.name %>"
        onerror="this.onerror=null; this.src='/assets/fallback.svg'"
      />
    </div>

    <div class="product-info">
     <h1><%= product.name %></h1>
      <p class="product-category"><i class="bi bi-tag"></i> <%= product.category %></p>
      <p class="product-price-large"><%= product.price.toLocaleString('es-AR') %> <span>puntos</span></p>

      <form action="/cart/add" method="POST">
        <input type="hidden" name="productId" value="<%= product.id %>" />
        <button type="submit" class="btn-add-cart">Agregar al Carrito</button>
      </form>

      <div class="product-description">
        <p><%= product.description %></p>
      </div>
    </div>
  </div>

  <section class="products-section">
  <h2 class="section-title">También te puede interesar</h2>
  <% if (related.length > 0) { %>
    <div class="products-grid">
      <% related.forEach(function(p) { %>
        <a href="/products/<%= p.id %>" class="product-card">
          <img
            src="<%= p.image || '/assets/fallback.svg' %>"
            alt="<%= p.name %>"
            onerror="this.onerror=null; this.src='/assets/fallback.svg'"
          />
          <p class="product-title"><%= p.name %></p>
          <p class="product-price"><%= p.price.toLocaleString('es-AR') %> <span class="puntos-label">puntos</span></p>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <p class="no-related">No hay productos relacionados disponibles.</p>
  <% } %>
</section>
</main>